{
  "name": "@rksan/object-diff",
  "version": "1.0.0",
  "files": [
    "./dist",
    "README.md",
    "LICENCE"
  ],
  "scripts": {
    "/-/-/ init /-/-/-/": "",
    "tsc:init": "tsc --init",
    "/-/-/-/ test /-/-/-/": "",
    "pretest": "rm -rf .nyc_output && rm -rf tsconfig.tsnode.json && tsc -p ./tsconfig.build.json --showConfig > tsconfig.tsnode.json",
    "test": "nyc ts-mocha --recursive --paths -p ./tsconfig.tsnode.json test/**/*.spec.ts",
    "precoverage": "rm -rf coverage && mkdir coverage",
    "coverage": "npm run test && nyc report --reporter=lcovonly",
    "/-/-/-/ build /-/-/-/": "",
    "prebuild:dts": "rm -rf dist  && rm -rf types-defines",
    "build:dts": "tsc -p ./tsconfig.build-type.json && tsc-alias -p ./tsconfig.build-type.json",
    "build:ts": "tsc -p ./tsconfig.build.json && tsc-alias -p ./tsconfig.build.json",
    "prebuild:browserify": "rm -rf bundle",
    "build:browserify": "node ./node_modules/browserify/bin/cmd.js ./dist/bandle.js -o ./bundle/object-diff.js",
    "build:browserify:min": "node ./node_modules/browserify/bin/cmd.js ./dist/bandle.js --debug | terser -c -m --source-map \"content=inline,url=inline\" -o ./bundle/object-diff.min.js",
    "build": "npm run build:dts && npm run build:ts && npm run build:browserify && npm run build:browserify:min"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/eslint-parser": "^7.22.15",
    "@babel/preset-env": "^7.22.20",
    "@types/chai": "^4.3.6",
    "@types/eslint": "^8.44.3",
    "@types/mocha": "^10.0.2",
    "@types/prettier": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "browserify": "^17.0.1",
    "chai": "^4.3.10",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jsonc": "^2.9.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jsonc-eslint-parser": "^2.3.0",
    "mocha": "^10.2.0",
    "nyc": "^15.1.0",
    "prettier": "^3.0.3",
    "terser": "^5.48.0",
    "tinyify": "^4.0.0",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT"
}
